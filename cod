        tk.Button(title_bar, text="−", font=('Segoe UI', 16, 'bold'), fg='white', bg=self.colors['primary'],
                 relief=tk.FLAT, command=self.minimize_window, cursor="hand2").pack(side=tk.RIGHT, padx=5, pady=8)
        
        title_bar.bind("<Button-1>", self.start_move)
        title_bar.bind("<B1-Motion>", self.on_move)
    
    def start_move(self, event):
        self.x = event.x
        self.y = event.y
    
    def on_move(self, event):
        deltax = event.x - self.x
        deltay = event.y - self.y
        x = self.root.winfo_x() + deltax
        y = self.root.winfo_y() + deltay
        self.root.geometry(f"+{x}+{y}")
    
    def minimize_window(self):
        self.root.iconify()
    
    def animate_exit(self):
        alpha = 1
        def fade_out():
            nonlocal alpha
            alpha -= 0.05
            if alpha >= 0:
                self.root.attributes('-alpha', alpha)
                self.root.after(20, fade_out)
            else:
                self.root.quit()
        fade_out()
    
    def update_time(self):
        self.time_label.config(text=time.strftime("%H:%M"))
        self.root.after(1000, self.update_time)
    
    def clear_frame(self):
        if self.current_frame:
            self.current_frame.destroy()
        self.current_frame = tk.Frame(self.main_frame, bg=self.colors['bg'])
        self.current_frame.pack(fill=tk.BOTH, expand=True, padx=15, pady=15)
    
