        entry.bind('<Return>', lambda e: save())
    
    def on_color_test_complete(self, correct, total, questions, answers, exit_test=False):
        if exit_test:
            self.test_active = False
            self.show_main_menu()
            return
        
        if total > 0:
            if correct >= 7:
                result = "✅ Нормальное цветовосприятие"
            elif correct >= 5:
                result = "⚠️ Лёгкие нарушения цветовосприятия"
            elif correct >= 3:
                result = "⚠️ Умеренные нарушения цветовосприятия"
            else:
                result = "🔴 Выраженные нарушения цветовосприятия (возможен дальтонизм)"
            
            self.db.save_test_result("Цветовосприятие", result, f"{correct}/{total}")
            ResultWindow.show(self.root, questions, answers, correct)
        
        self.test_active = False
        self.show_main_menu()
    
