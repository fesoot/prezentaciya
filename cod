    def show_history(self):
        history = self.db.get_history()
        if not history:
            messagebox.showinfo("История", "История тестов пуста")
            return
        text = "📜 ИСТОРИЯ ТЕСТОВ 📜\n\n"
        for i, test in enumerate(reversed(history), 1):
            text += f"{i}. {test['date'][:16]}\n   {test['test_type']}: {test['result']}\n"
            if test.get('details'):
                text += f"   📝 {test['details']}\n"
            text += "\n"
        messagebox.showinfo("История тестов", text)
    
