class Database:
    def __init__(self):
        self.filename = 'eyescan_data.json'
        self.data = self.load_data()
        self.fix_data_structure()
    
    def load_data(self):
        if os.path.exists(self.filename):
            try:
                with open(self.filename, 'r', encoding='utf-8') as f:
                    return json.load(f)
            except:
                return self.get_default_data()
        return self.get_default_data()
    
    def get_default_data(self):
        return {
            'tests_history': [],
            'user_profile': {'name': '', 'last_test_date': '', 'created_at': str(datetime.now())},
            'user_location': {'city': 'Москва'}
        }
    
    def fix_data_structure(self):
        needs_save = False
        if 'user_location' not in self.data:
            self.data['user_location'] = {'city': 'Москва'}
            needs_save = True
        if 'tests_history' not in self.data:
            self.data['tests_history'] = []
            needs_save = True
        if 'user_profile' not in self.data:
            self.data['user_profile'] = {'name': '', 'last_test_date': '', 'created_at': str(datetime.now())}
            needs_save = True
        if needs_save:
            self.save_data()
    
    def save_data(self):
        with open(self.filename, 'w', encoding='utf-8') as f:
            json.dump(self.data, f, ensure_ascii=False, indent=2)
    
    def save_test_result(self, test_type, result, details=""):
        self.data['tests_history'].append({
            'date': str(datetime.now()),
            'test_type': test_type,
            'result': result,
            'details': details
        })
        self.data['user_profile']['last_test_date'] = str(datetime.now())
        self.save_data()
    
    def get_history(self):
        return self.data.get('tests_history', [])
    
    def save_user_name(self, name):
        self.data['user_profile']['name'] = name
        self.save_data()
    
    def get_user_name(self):
        return self.data.get('user_profile', {}).get('name', '')
    
    def save_user_city(self, city):
        self.data['user_location']['city'] = city
        self.save_data()
    
    def get_user_city(self):
        return self.data.get('user_location', {}).get('city', 'Москва')


class TrackingEye(tk.Canvas):
    """Глаз, который следит за курсором мыши"""
    
    def __init__(self, parent, size=90):
        super().__init__(parent, width=size, height=size, highlightthickness=0, bg=parent.cget('bg'))
        self.size = size
        self.center_x = size // 2
        self.center_y = size // 2
        self.max_offset = 12  # Максимальное смещение зрачка
        
        # Рисуем глаз
        self.draw_eye()
        
        # Привязываем движение мыши
        self.bind("<Motion>", self.on_mouse_move)
        # Также следим за движением мыши на родительском виджете
        parent.bind("<Motion>", self.on_mouse_move)
    
    def draw_eye(self):
        self.delete("all")
        
        # Белок глаза
        self.create_oval(self.center_x-38, self.center_y-33, self.center_x+38, self.center_y+33, 
                        fill='white', outline='#3b82f6', width=4)
        
        # Радужка (внешняя)
        self.iris = self.create_oval(self.center_x-16, self.center_y-14, self.center_x+16, self.center_y+14, 
                                     fill='#3b82f6', outline='#2563eb', width=2)
        
        # Зрачок (будет двигаться)
        self.pupil = self.create_oval(self.center_x-7, self.center_y-6, self.center_x+7, self.center_y+6, 
                                      fill='#1e3a8a')
        
        # Блик
        self.create_oval(self.center_x-3, self.center_y-10, self.center_x+2, self.center_y-5, fill='white')
        
        # Верхние ресницы для красоты
        self.create_line(self.center_x-38, self.center_y-33, self.center_x-48, self.center_y-43, 
                        width=3, fill='#3b82f6')
        self.create_line(self.center_x-28, self.center_y-36, self.center_x-36, self.center_y-48, 
                        width=3, fill='#3b82f6')
        self.create_line(self.center_x+38, self.center_y-33, self.center_x+48, self.center_y-43, 
                        width=3, fill='#3b82f6')
        self.create_line(self.center_x+28, self.center_y-36, self.center_x+36, self.center_y-48, 
                        width=3, fill='#3b82f6')
    
    def on_mouse_move(self, event):
        # Получаем координаты курсора относительно холста
        x = event.x
        y = event.y
        
        # Если курсор за пределами холста, используем центр
        if x < 0 or x > self.size or y < 0 or y > self.size:
            # Возвращаем зрачок в центр
            self.move_pupil(self.center_x, self.center_y)
            return
        
        # Вычисляем направление от центра к курсору
        dx = x - self.center_x
        dy = y - self.center_y
        
        # Нормализуем вектор и ограничиваем смещение
        distance = math.sqrt(dx*dx + dy*dy)
        if distance > 0:
            dx = dx / distance
            dy = dy / distance
        
        # Смещаем зрачок
        offset_x = int(dx * self.max_offset)
        offset_y = int(dy * self.max_offset)
        
        # Ограничиваем, чтобы зрачок не выходил за пределы радужки
        offset_x = max(-10, min(10, offset_x))
        offset_y = max(-8, min(8, offset_y))
        
        # Двигаем зрачок
        self.move_pupil(self.center_x + offset_x, self.center_y + offset_y)
    
    def move_pupil(self, new_x, new_y):
        """Перемещает зрачок в указанные координаты"""
        self.coords(self.pupil, new_x-7, new_y-6, new_x+7, new_y+6)


class ColorTest(tk.Frame):
    """Тест на цветовосприятие"""
    
    def __init__(self, parent, on_complete):
        super().__init__(parent, bg='#0f172a')
        self.on_complete = on_complete
        self.current_q = 0
        self.answers = []
        
        self.questions = [
            {"text": "Какую цифру вы видите на цветных кругах?", "correct": "12", 
             "options": ["12", "3", "8", "96"], "colors": ["#FF0000", "#00FF00", "#0000FF", "#FFFF00"], "value": "12"},
            {"text": "Какую цифру вы видите?", "correct": "8", 
             "options": ["8", "3", "5", "2"], "colors": ["#FF6347", "#4682B4", "#32CD32", "#FFD700"], "value": "8"},
            {"text": "Какую цифру вы видите?", "correct": "3", 
             "options": ["3", "8", "5", "2"], "colors": ["#FF4500", "#1E90FF", "#DC143C", "#FF69B4"], "value": "3"},
            {"text": "Какое число вы видите?", "correct": "96", 
             "options": ["96", "69", "6", "9"], "colors": ["#8B0000", "#006400", "#00008B", "#800080"], "value": "96"},
            {"text": "Какую фигуру вы видите?", "correct": "Треугольник", 
             "options": ["Треугольник", "Круг", "Квадрат", "Ромб"], "colors": ["#FF0000", "#00FF00", "#0000FF", "#FF00FF"], "shape": "triangle"},
            {"text": "Какую фигуру вы видите?", "correct": "Круг", 
             "options": ["Круг", "Треугольник", "Квадрат", "Ромб"], "colors": ["#FF6347", "#32CD32", "#FFD700", "#9B59B6"], "shape": "circle"},
            {"text": "Какую фигуру вы видите?", "correct": "Квадрат", 
             "options": ["Квадрат", "Круг", "Треугольник", "Ромб"], "colors": ["#FF4500", "#1E90FF", "#DC143C", "#FF69B4"], "shape": "square"},
            {"text": "Какую фигуру вы видите?", "correct": "Ромб", 
             "options": ["Ромб", "Круг", "Квадрат", "Треугольник"], "colors": ["#8B0000", "#006400", "#00008B", "#800080"], "shape": "diamond"},
        ]
        
        self.setup_ui()
        self.show_question()
    
    def setup_ui(self):
        header = tk.Frame(self, bg='#06b6d4', height=50)
        header.pack(fill=tk.X, pady=(0, 15))
        header.pack_propagate(False)
        
        tk.Label(header, text="🎨 ТЕСТ НА ЦВЕТОВОСПРИЯТИЕ", 
                font=('Segoe UI', 13, 'bold'), fg='white', bg='#06b6d4').pack(side=tk.LEFT, padx=15)
        
        tk.Button(header, text="✕", font=('Segoe UI', 14, 'bold'), fg='white', bg='#06b6d4',
                 relief=tk.FLAT, command=self.exit_test, cursor="hand2").pack(side=tk.RIGHT, padx=15)
        
        self.progress_label = tk.Label(self, text="Вопрос 1 из 8", font=('Segoe UI', 11),
                                       bg='#0f172a', fg='#94a3b8')
        self.progress_label.pack(pady=5)
        
        self.question_label = tk.Label(self, text="", font=('Segoe UI', 13, 'bold'),
                                       bg='#0f172a', fg='#FFD700', wraplength=420)
        self.question_label.pack(pady=10)
        
        canvas_frame = tk.Frame(self, bg='#1e293b')
        canvas_frame.pack(pady=10, padx=15, fill=tk.X)
        
        self.canvas = tk.Canvas(canvas_frame, width=420, height=140, bg='#1e293b', highlightthickness=0)
        self.canvas.pack(pady=15)
        
        self.options_frame = tk.Frame(self, bg='#0f172a')
        self.options_frame.pack(pady=15)
    
    def draw_figure(self, pos, shape_type):
        if shape_type == "triangle":
            points = [pos, 35, pos-20, 90, pos+20, 90]
            self.canvas.create_polygon(points, fill='#FFD700', outline='white', width=2)
        elif shape_type == "circle":
            self.canvas.create_oval(pos-18, 52, pos+18, 88, fill='#FF4500', outline='white', width=2)
        elif shape_type == "square":
            self.canvas.create_rectangle(pos-18, 52, pos+18, 88, fill='#FF4500', outline='white', width=2)
        elif shape_type == "diamond":
            points = [pos, 52, pos+18, 70, pos, 88, pos-18, 70]
            self.canvas.create_polygon(points, fill='#FF4500', outline='white', width=2)
    
    def show_question(self):
        q = self.questions[self.current_q]
        self.question_label.config(text=q["text"])
        self.progress_label.config(text=f"📋 Вопрос {self.current_q + 1} из {len(self.questions)}")
        
        self.canvas.delete("all")
        positions = [60, 150, 240, 330]
        
        for i, (pos, color) in enumerate(zip(positions, q["colors"])):
            self.canvas.create_oval(pos-35, 20, pos+35, 120, fill=color, outline='white', width=2)
        
        if "value" in q:
            if q["value"] == "96":
                self.canvas.create_text(95, 70, text="9", font=('Arial', 22, 'bold'), fill='white')
                self.canvas.create_text(295, 70, text="6", font=('Arial', 22, 'bold'), fill='white')
            else:
                for pos in positions:
                    self.canvas.create_text(pos, 70, text=q["value"], font=('Arial', 22, 'bold'), fill='white')
        else:
            for pos in positions:
                self.draw_figure(pos, q["shape"])
        
        for w in self.options_frame.winfo_children():
            w.destroy()
        
        for i, opt in enumerate(q["options"]):
            btn = tk.Button(self.options_frame, text=opt, font=('Segoe UI', 12, 'bold'),
                           command=lambda o=opt: self.answer(o),
                           width=10, relief=tk.RAISED, bg='#1e293b', 
                           fg='#f1f5f9', cursor="hand2", padx=10, pady=8)
            btn.grid(row=i//2, column=i%2, padx=10, pady=8)
    
    def answer(self, answer):
        self.answers.append(answer)
        self.current_q += 1
        
        if self.current_q < len(self.questions):
            self.show_question()
        else:
            self.complete_test()
    
    def complete_test(self):
        correct = sum(1 for i, a in enumerate(self.answers) 
                     if a == self.questions[i]["correct"])
        self.on_complete(correct, len(self.questions), self.questions, self.answers)
    
    def exit_test(self):
        if messagebox.askyesno("Выход", "Прервать тест?"):
            self.on_complete(0, 0, None, None, exit_test=True)


class ResultWindow:
    @staticmethod
    def show(parent, questions, user_answers, correct_count):
        window = tk.Toplevel(parent)
        window.title("Результаты теста")
        window.geometry("500x600")
        window.configure(bg='#0f172a')
        window.transient(parent)
        window.grab_set()
        
        header = tk.Frame(window, bg='#3b82f6', height=60)
        header.pack(fill=tk.X)
        header.pack_propagate(False)
        tk.Label(header, text="📊 РЕЗУЛЬТАТЫ ТЕСТА", font=('Segoe UI', 16, 'bold'),
                fg='white', bg='#3b82f6').pack(pady=15)
        
        total = len(questions)
        percentage = (correct_count / total) * 100
        
        stats_frame = tk.Frame(window, bg='#1e293b')
        stats_frame.pack(fill=tk.X, pady=10, padx=15, ipady=10)
        
        if percentage >= 80:
            color = '#10b981'
            status = "✅ НОРМАЛЬНОЕ ЦВЕТОВОСПРИЯТИЕ"
        elif percentage >= 60:
            color = '#f59e0b'
            status = "⚠️ ЛЕГКИЕ НАРУШЕНИЯ"
        elif percentage >= 40:
            color = '#f97316'
            status = "⚠️ СРЕДНИЕ НАРУШЕНИЯ"
        else:
            color = '#ef4444'
            status = "🔴 ВЫРАЖЕННЫЕ НАРУШЕНИЯ"
        
        tk.Label(stats_frame, text=status, font=('Segoe UI', 16, 'bold'),
                fg=color, bg='#1e293b').pack()
        tk.Label(stats_frame, text=f"Правильных ответов: {correct_count} из {total} ({int(percentage)}%)",
                font=('Segoe UI', 12), fg='#94a3b8', bg='#1e293b').pack(pady=5)
        
        canvas = tk.Canvas(window, bg='#0f172a', highlightthickness=0)
        scrollbar = tk.Scrollbar(window, orient="vertical", command=canvas.yview)
        scrollable_frame = tk.Frame(canvas, bg='#0f172a')
        
        scrollable_frame.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        canvas.create_window((0, 0), window=scrollable_frame, anchor="nw", width=470)
        canvas.configure(yscrollcommand=scrollbar.set)
        
        tk.Label(scrollable_frame, text="📋 ПОДРОБНЫЙ РАЗБОР:", 
                font=('Segoe UI', 14, 'bold'), fg='#3b82f6', bg='#0f172a').pack(anchor='w', pady=(10, 5), padx=10)
        
        for i, (q, user_ans) in enumerate(zip(questions, user_answers)):
            is_correct = (user_ans == q["correct"])
            card = tk.Frame(scrollable_frame, bg='#1e293b')
            card.pack(fill=tk.X, pady=5, padx=10)
            
            status_text = "✅" if is_correct else "❌"
            status_color = "#10b981" if is_correct else "#ef4444"
            
            tk.Label(card, text=f"{status_text} Вопрос {i+1}", 
                    font=('Segoe UI', 11, 'bold'), fg=status_color, bg='#1e293b').pack(anchor='w', padx=10, pady=5)
            tk.Label(card, text=f"✓ Правильный ответ: {q['correct']}", 
                    font=('Segoe UI', 10), fg='#10b981', bg='#1e293b').pack(anchor='w', padx=10)
            tk.Label(card, text=f"✗ Ваш ответ: {user_ans}", font=('Segoe UI', 10),
                    fg=status_color, bg='#1e293b').pack(anchor='w', padx=10, pady=(0, 8))
        
        canvas.pack(side="left", fill="both", expand=True, padx=10)
        scrollbar.pack(side="right", fill="y")
        
        tk.Button(window, text="ЗАКРЫТЬ", font=('Segoe UI', 12, 'bold'),
                 bg='#3b82f6', fg='white', command=window.destroy,
                 cursor="hand2", relief=tk.FLAT, pady=8).pack(pady=15, fill=tk.X, padx=30)


