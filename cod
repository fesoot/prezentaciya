    def search_clinics(self):
        city = self.city_var.get()
        if not city:
            messagebox.showwarning("Внимание", "Выберите город")
            return
        
        for w in self.results_frame.winfo_children():
            w.destroy()
        
        if city in self.clinics_db:
            clinics = self.clinics_db[city]
        else:
            clinics = [{
                "name": f"🏥 Офтальмологические клиники в {city}",
                "address": f"📍 г. {city}",
                "phone": "📞 Поиск на Яндекс.Картах",
                "hours": "🕐 Нажмите для поиска",
                "url": f"https://yandex.ru/maps/?text=офтальмологическая+клиника+{city}"
