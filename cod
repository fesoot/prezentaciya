    def enter_name(self):
        dialog = tk.Toplevel(self.root)
        dialog.title("Профиль")
        dialog.geometry("350x180")
        dialog.configure(bg=self.colors['card_bg'])
        dialog.transient(self.root)
        dialog.grab_set()
        
        tk.Label(dialog, text="Ваше имя", font=('Segoe UI', 14, 'bold'),
                bg=self.colors['card_bg'], fg=self.colors['text']).pack(pady=(25, 10))
        
        entry = tk.Entry(dialog, font=('Segoe UI', 12), width=25,
                        bg=self.colors['bg'], fg=self.colors['text'], insertbackground='white')
        entry.pack(pady=5, padx=20)
        entry.focus()
        
        def save():
            name = entry.get().strip()
            if name:
                self.db.save_user_name(name)
