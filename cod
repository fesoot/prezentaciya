        self.selected_acuity = acuity
        messagebox.showinfo("Выбрано", f"👁️ Острота зрения: {acuity}")
    
    def complete_acuity_test(self):
        if not self.test_active:
            return
        if self.selected_acuity:
            result = f"Острота зрения: {self.selected_acuity}"
            self.db.save_test_result("Острота зрения", result)
            messagebox.showinfo("Результат", result)
        else:
            if messagebox.askyesno("Внимание", "Завершить без результата?"):
                pass
            else:
                return
        self.test_active = False
        self.show_main_menu()
    
    def exit_test(self):
        if messagebox.askyesno("Выход", "Прервать тест?"):
            self.test_active = False
            self.show_main_menu()
    
    def show_astigmatism_test(self):
        self.clear_frame()
        self.test_active = True
        
        header = tk.Frame(self.current_frame, bg=self.colors['warning'], height=50)
        header.pack(fill=tk.X, pady=(0, 15))
        header.pack_propagate(False)
        
        tk.Label(header, text="⭐ ТЕСТ НА АСТИГМАТИЗМ", font=('Segoe UI', 13, 'bold'),
                fg='white', bg=self.colors['warning']).pack(side=tk.LEFT, padx=15)
        
        tk.Button(header, text="✕", font=('Segoe UI', 14, 'bold'), fg='white', bg=self.colors['warning'],
                 relief=tk.FLAT, command=self.exit_test, cursor="hand2").pack(side=tk.RIGHT, padx=15)
        
        star_frame = tk.Frame(self.current_frame, bg='white', width=350, height=350)
        star_frame.pack(pady=20)
        star_frame.pack_propagate(False)
        
        canvas = tk.Canvas(star_frame, width=350, height=350, bg='white', highlightthickness=1)
        canvas.pack()
        
        cx, cy = 175, 175
        radius = 150
        for i in range(24):
            angle = i * 15
            rad = math.radians(angle)
            x = cx + radius * math.cos(rad)
            y = cy + radius * math.sin(rad)
            canvas.create_line(cx, cy, x, y, width=2, fill='black')
        
        canvas.create_oval(cx-10, cy-10, cx+10, cy+10, fill='white', outline='black', width=2)
        
        btn_frame = tk.Frame(self.current_frame, bg=self.colors['bg'])
        btn_frame.pack(pady=20)
        
        tk.Button(btn_frame, text="✅ ДА, ВСЕ ЛИНИИ ОДИНАКОВЫЕ", font=('Segoe UI', 11, 'bold'),
                 command=lambda: self.check_astigmatism(True), cursor="hand2",
                 bg=self.colors['success'], fg='white', padx=15, pady=8, relief=tk.FLAT).pack(side=tk.LEFT, padx=10)
        
        tk.Button(btn_frame, text="❌ НЕТ, ЛИНИИ РАЗНЫЕ", font=('Segoe UI', 11, 'bold'),
                 command=lambda: self.check_astigmatism(False), cursor="hand2",
                 bg=self.colors['danger'], fg='white', padx=15, pady=8, relief=tk.FLAT).pack(side=tk.LEFT, padx=10)
    
